rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.:@/]+$'); }

    function isValidScoutSession(data) {
      return data.keys().hasAll(['userId', 'query', 'response', 'createdAt']) &&
        data.keys().size() == 4 &&
        data.userId == request.auth.uid &&
        data.query is string && data.query.size() <= 10000 &&
        data.response is string && data.response.size() <= 50000 &&
        data.createdAt is timestamp;
    }

    function isValidFaceitRecord(data) {
      return data.keys().hasAll(['username', 'elo', 'level', 'avatarUrl', 'coverImageUrl', 'stats', 'segments', 'syncedAt']) &&
        data.keys().size() == 8 &&
        data.username is string && data.username.size() <= 100 &&
        (data.elo == null || data.elo is int || data.elo is float) &&
        (data.level == null || data.level is int || data.level is float) &&
        data.avatarUrl is string && data.avatarUrl.size() <= 2000 &&
        data.coverImageUrl is string && data.coverImageUrl.size() <= 2000 &&
        data.stats is map &&
        data.segments is list &&
        data.syncedAt is timestamp;
    }

    function isValidFaceitMatch(data) {
      return data.keys().hasAll(['matchId', 'username', 'date', 'map', 'kills', 'deaths', 'kd', 'result', 'elo', 'stats']) &&
        data.keys().size() == 10 &&
        data.matchId is string && data.matchId.size() <= 128 &&
        data.username is string && data.username.size() <= 100 &&
        (data.date is int || data.date is float) &&
        data.map is string && data.map.size() <= 100 &&
        (data.kills is int || data.kills is float) &&
        (data.deaths is int || data.deaths is float) &&
        (data.kd is int || data.kd is float) &&
        data.result is string && (data.result == 'W' || data.result == 'L') &&
        (data.elo == null || data.elo is int || data.elo is float) &&
        data.stats is map;
    }

    match /scoutSessions/{sessionId} {
      allow read: if isSignedIn() && isValidId(sessionId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(sessionId) && isValidScoutSession(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(sessionId) && existing().userId == request.auth.uid && isValidScoutSession(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isValidId(sessionId) && existing().userId == request.auth.uid;
    }

    match /faceitStats/{username} {
      allow read: if true;
      allow write: if isValidId(username) && isValidFaceitRecord(incoming()) && incoming().syncedAt == request.time;
    }

    match /faceitHistory/{historyId} {
      allow read: if true;
      allow create: if isValidId(historyId) && isValidFaceitRecord(incoming()) && incoming().syncedAt == request.time;
      allow delete, update: if false;
    }

    match /faceitMatches/{matchId} {
      allow read, list: if true;
      allow create: if isValidId(matchId) && isValidFaceitMatch(incoming());
      allow delete, update: if false;
    }
  }
}
